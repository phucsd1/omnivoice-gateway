APP_ENV=development
WORKER_MODE=mock

DATABASE_URL=sqlite:///./omnivoice_gateway.db
STORAGE_DIR=./storage

PUBLIC_API_BASE_URL=
FRONTEND_ORIGINS=http://localhost:5173,http://127.0.0.1:5173

WORKER_TOKEN=default_secure_worker_token_12345
WORKER_IDLE_TIMEOUT_SECONDS=600
WORKER_POLL_INTERVAL_SECONDS=3

# Kaggle credentials (required only if WORKER_MODE=kaggle)
KAGGLE_USERNAME=
KAGGLE_KEY=
KAGGLE_KERNEL_REF=
KAGGLE_KERNEL_SLUG=omnivoice-worker
KAGGLE_KERNEL_TITLE=OmniVoice Worker
KAGGLE_ACCELERATOR=NvidiaTeslaT4
KAGGLE_TIMEOUT_SECONDS=3600
KAGGLE_WORKER_DIR=../kaggle_worker


LOG_LEVEL=info
